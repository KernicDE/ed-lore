---
import BaseLayout from '../../layouts/BaseLayout.astro';
import graphData from '../../data/lore_graph.json';
import SearchIsland from '../../components/hud/SearchIsland';
import EntityGraph from '../../components/graph/EntityGraph';
import type { MiniGraphData, GraphNode, GraphLink } from '../../components/graph/EntityGraph';

export function getStaticPaths() {
  return Object.values(graphData.arcs).map((a) => ({
    params: { id: a.id },
  }));
}

const { id } = Astro.params;
const arc = graphData.arcs[id] as any;
const baseUrl = (import.meta.env.BASE_URL || '').replace(/\/$/, '');

const arcArticles = graphData.articles
  .filter((a) => a.arc_id === id)
  .sort((a, b) => (b.date || '').localeCompare(a.date || ''));

const keyEntities = (arc?.key_entities || [])
  .slice(0, 8)
  .map((e: any) => graphData.entities[e.id])
  .filter(Boolean);

// Build mini-map: arc node at centre, key entities as depth-1, their connections as depth-2
const miniNodes: GraphNode[] = [];
const miniLinks: GraphLink[] = [];
const edgeSet = new Set<string>();

if (arc) {
  // Arc as centre node (type='arc' gets its own colour)
  miniNodes.push({ id: arc.id, name: arc.name, type: 'arc', mentions: arc.mention_count ?? 0, depth: 0 });

  const keyIds = new Set<string>();
  for (const ke of (arc.key_entities ?? []) as any[]) {
    const ent = (graphData.entities as any)[ke.id];
    if (!ent) continue;
    keyIds.add(ke.id);
    miniNodes.push({ id: ke.id, name: ent.name, type: ent.type, mentions: ent.mention_count ?? 0, depth: 1 });
    const key = [arc.id, ke.id].sort().join('|');
    if (!edgeSet.has(key)) {
      edgeSet.add(key);
      miniLinks.push({ source: arc.id, target: ke.id, weight: ke.mentions ?? 1 });
    }
  }

  // Edges between key entities that co-occur
  for (const ke of (arc.key_entities ?? []) as any[]) {
    const ent = (graphData.entities as any)[ke.id];
    if (!ent) continue;
    for (const rel of (ent.related_entities ?? []) as any[]) {
      if (keyIds.has(rel.id)) {
        const key = [ke.id, rel.id].sort().join('|');
        if (!edgeSet.has(key)) {
          edgeSet.add(key);
          miniLinks.push({ source: ke.id, target: rel.id, weight: rel.mentions ?? 1 });
        }
      }
    }
  }

  // 2nd-degree connections from key entities (capped at 15)
  const seen = new Set<string>([arc.id, ...keyIds]);
  let secondCount = 0;
  outer: for (const ke of (arc.key_entities ?? []) as any[]) {
    const ent = (graphData.entities as any)[ke.id];
    if (!ent) continue;
    for (const rel of (ent.related_entities ?? []) as any[]) {
      if (secondCount >= 15) break outer;
      if (!seen.has(rel.id)) {
        const n2 = (graphData.entities as any)[rel.id];
        if (!n2) continue;
        seen.add(rel.id);
        secondCount++;
        miniNodes.push({ id: rel.id, name: n2.name, type: n2.type, mentions: n2.mention_count ?? 0, depth: 2 });
        const key = [ke.id, rel.id].sort().join('|');
        if (!edgeSet.has(key)) {
          edgeSet.add(key);
          miniLinks.push({ source: ke.id, target: rel.id, weight: rel.mentions ?? 1 });
        }
      }
    }
  }
}

const miniGraphData: MiniGraphData = { nodes: miniNodes, links: miniLinks };

const sigColors: Record<string, string> = {
  low: 'var(--elite-green)',
  medium: 'var(--elite-yellow)',
  high: 'var(--elite-orange)',
  critical: 'var(--elite-red)',
};
---

<BaseLayout title={`${arc?.name || id} — GalNet Chronicle`}>
  <header class="hud-header">
    <div>
      <a href={`${baseUrl}/`} style="text-decoration: none;" data-home-link>
        <span class="hud-title">‹ GalNet Chronicle</span>
      </a>
    </div>
    <div style="display: flex; align-items: center; gap: 16px;">
      <a href={`${baseUrl}/map/`} class="hud-nav-link">Map</a>
      <SearchIsland client:idle baseUrl={baseUrl} />
    </div>
  </header>

  <div style="padding: 24px; max-width: 900px; margin: 0 auto;">
    <div class="holo-panel blue">
      <div style="margin-bottom: 12px;">
        <h1 style="margin: 0; font-family: var(--font-hud); font-size: 24px; color: var(--elite-blue);">
          {arc?.name || id}
        </h1>
        <div style="font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); margin-top: 6px;">
          {arc?.first_seen_date} → {arc?.last_seen_date} · {arc?.mention_count || 0} articles
        </div>
      </div>
      {arc?.significance && (
        <div style="display: flex; align-items: center; gap: 8px;">
          <span style="font-family: var(--font-mono); font-size: 10px; color: var(--text-dim); text-transform: uppercase;">Significance</span>
          <span style={{
            fontFamily: 'var(--font-mono)',
            fontSize: 11,
            color: sigColors[arc.significance] || 'var(--text-dim)',
            textTransform: 'uppercase',
            letterSpacing: '1px',
          }}>
            {arc.significance}
          </span>
        </div>
      )}
    </div>

    {arc?.summary && (
      <div class="holo-panel">
        <div class="holo-title">Summary</div>
        <div style="font-size: 14px; color: var(--text-secondary); line-height: 1.6;">
          {arc.summary}
        </div>
      </div>
    )}

    {arc?.description && (
      <div class="holo-panel">
        <div class="holo-title">Overview</div>
        <div style="font-size: 14px; color: var(--text-secondary); line-height: 1.6;">
          {arc.description}
        </div>
      </div>
    )}

    {arc?.status && (
      <div class="holo-panel">
        <div class="holo-title">Status</div>
        <div style="font-size: 14px; color: var(--text-secondary); line-height: 1.6;">
          {arc.status}
        </div>
      </div>
    )}

    {arc?.outcome && (
      <div class="holo-panel">
        <div class="holo-title">Outcome</div>
        <div style="font-size: 14px; color: var(--text-secondary); line-height: 1.6;">
          {arc.outcome}
        </div>
      </div>
    )}

    {arc?.phases && arc.phases.length > 0 && (
      <div class="holo-panel">
        <div class="holo-title">Phases</div>
        <div style="display: flex; flex-direction: column; gap: 8px;">
          {arc.phases.map((phase: string, idx: number) => (
            <div style="display: flex; align-items: center; gap: 12px;">
              <span style="font-family: var(--font-mono); font-size: 11px; color: var(--elite-blue); min-width: 24px;">{String(idx + 1).padStart(2, '0')}</span>
              <span style="font-size: 13px; color: var(--text-primary);">{phase}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    {/* Relationship mini-map */}
    {miniNodes.length > 1 && (
      <div class="holo-panel" style="padding: 0; overflow: hidden;">
        <div style="padding: 20px 20px 0;"><div class="holo-title">Connection Map</div></div>
        <EntityGraph client:visible mode="mini" miniData={miniGraphData} baseUrl={baseUrl} />
      </div>
    )}

    {keyEntities.length > 0 && (
      <div class="holo-panel">
        <div class="holo-title">Key Figures</div>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 8px;">
          {keyEntities.map((ent: any) => (
            <a href={`${baseUrl}/entity/${ent.id}/`} class="entity-card" style="text-decoration: none;">
              <div class={`entity-icon ${ent.type || 'person'}`}>
                {ent.type === 'person' ? 'P' : ent.type === 'faction' ? 'F' : 'L'}
              </div>
              <div>
                <div class="entity-name">{ent.name}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="holo-panel">
      <div class="holo-title">Chronology ({arcArticles.length} articles)</div>
      {arcArticles.length === 0 && (
        <div style="color: var(--text-dim); font-size: 13px;">No articles found.</div>
      )}
      {arcArticles.map((art) => (
        <div key={art.uuid} style="padding: 10px 0; border-bottom: 1px solid var(--border-default);">
          <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-dim);">{art.date}</div>
          <a href={`${baseUrl}/?article=${art.uuid}`} style="font-size: 14px; font-weight: 500; color: var(--text-primary); text-decoration: none;">
            {art.title}
          </a>
          {art.summary && (
            <div style="margin-top: 4px; font-size: 12px; color: var(--text-secondary); line-height: 1.4;">
              {art.summary}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
