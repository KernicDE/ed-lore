---
import BaseLayout from '../../layouts/BaseLayout.astro';
import graphData from '../../data/lore_graph.json';

export function getStaticPaths() {
  return Object.values(graphData.entities).map((e) => ({
    params: { id: e.id },
  }));
}

const { id } = Astro.params;
const entity = graphData.entities[id];

const entityArticles = graphData.articles
  .filter((a) => {
    const allNames = [...a.entities, ...a.groups, ...a.locations, ...(a.persons || []), ...(a.technologies || [])];
    return allNames.some((n) => n.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '') === id);
  })
  .sort((a, b) => (b.date || '').localeCompare(a.date || ''));

const related = (entity?.related_entities || [])
  .slice(0, 8)
  .map((r) => graphData.entities[r.id])
  .filter(Boolean);

const typeLabels: Record<string, string> = {
  person: 'Person',
  faction: 'Faction / Organisation',
  location: 'System / Location',
  technology: 'Technology / Ship',
};

function formatNumber(n: number): string {
  if (n >= 1_000_000_000) return (n / 1_000_000_000).toFixed(1) + 'B';
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K';
  return String(n);
}
---

<BaseLayout title={`${entity?.name || id} — GalNet Chronicle`}>
  <header class="hud-header">
    <div>
      <a href={`${(import.meta.env.BASE_URL || '').replace(/\/$/, '')}/`} style="text-decoration: none;" data-home-link>
        <span class="hud-title">‹ GalNet Chronicle</span>
      </a>
    </div>
    <span class="hud-subtitle">Entity Profile</span>
  </header>

  <div style="padding: 24px; max-width: 900px; margin: 0 auto;">
    <div class="holo-panel">
      <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 16px;">
        <div class={`entity-icon ${entity?.type || 'person'}`} style="width: 48px; height: 48px; font-size: 18px;">
          {entity?.type === 'person' ? 'P' : entity?.type === 'faction' ? 'F' : entity?.type === 'technology' ? 'T' : 'L'}
        </div>
        <div>
          <h1 style="margin: 0; font-family: var(--font-hud); font-size: 24px; color: var(--elite-orange);">
            {entity?.name || id}
          </h1>
          <div style="font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); margin-top: 4px;">
            {typeLabels[entity?.type || 'person'] || 'Unknown'} ·
            First seen {entity?.first_seen_date || 'Unknown'} ·
            {entity?.mention_count || 0} mentions
          </div>
        </div>
      </div>
      {entity?.last_seen_date && (
        <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-secondary);">
          Active: {entity.first_seen_date} → {entity.last_seen_date}
        </div>
      )}
    </div>

    {/* Bio / Description */}
    {entity?.bio && (
      <div class="holo-panel">
        <div class="holo-title">Description</div>
        <div style="font-size: 14px; color: var(--text-secondary); line-height: 1.6;">
          {entity.bio}
        </div>
      </div>
    )}

    {/* Location data from EDSM */}
    {entity?.type === 'location' && (
      <div class="holo-panel">
        <div class="holo-title">System Data</div>
        {entity?.coords && (
          <div style="font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary); margin-bottom: 8px;">
            Coordinates: [{entity.coords.x}, {entity.coords.y}, {entity.coords.z}]
          </div>
        )}
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 8px; font-size: 13px;">
          {entity?.allegiance && (
            <div><span style="color: var(--text-dim);">Allegiance:</span> <span style="color: var(--text-primary);">{entity.allegiance}</span></div>
          )}
          {entity?.government && (
            <div><span style="color: var(--text-dim);">Government:</span> <span style="color: var(--text-primary);">{entity.government}</span></div>
          )}
          {entity?.controlling_faction && (
            <div><span style="color: var(--text-dim);">Controlling Faction:</span> <span style="color: var(--text-primary);">{entity.controlling_faction}</span></div>
          )}
          {entity?.security && (
            <div><span style="color: var(--text-dim);">Security:</span> <span style="color: var(--text-primary);">{entity.security}</span></div>
          )}
          {entity?.economy && (
            <div><span style="color: var(--text-dim);">Economy:</span> <span style="color: var(--text-primary);">{entity.economy}</span></div>
          )}
          {entity?.population && (
            <div><span style="color: var(--text-dim);">Population:</span> <span style="color: var(--text-primary);">{formatNumber(entity.population)}</span></div>
          )}
        </div>
      </div>
    )}

    {/* External links */}
    {(entity?.edsm_url || entity?.inara_url) && (
      <div class="holo-panel blue">
        <div class="holo-title blue">External References</div>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          {entity?.edsm_url && (
            <a href={entity.edsm_url} target="_blank" rel="noopener" style="font-family: var(--font-mono); font-size: 12px; color: var(--elite-blue); text-decoration: none; border: 1px solid var(--elite-blue-dim); padding: 6px 14px;">
              EDSM ↗
            </a>
          )}
          {entity?.inara_url && (
            <a href={entity.inara_url} target="_blank" rel="noopener" style="font-family: var(--font-mono); font-size: 12px; color: var(--elite-blue); text-decoration: none; border: 1px solid var(--elite-blue-dim); padding: 6px 14px;">
              Inara ↗
            </a>
          )}
        </div>
      </div>
    )}

    {related.length > 0 && (
      <div class="holo-panel blue">
        <div class="holo-title blue">Related Entities</div>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 8px;">
          {related.map((rel) => (
            <a href={`${(import.meta.env.BASE_URL || '').replace(/\/$/, '')}/entity/${rel.id}/`} class="entity-card" style="text-decoration: none;">
              <div class={`entity-icon ${rel.type || 'person'}`}>
                {rel.type === 'person' ? 'P' : rel.type === 'faction' ? 'F' : rel.type === 'technology' ? 'T' : 'L'}
              </div>
              <div>
                <div class="entity-name">{rel.name}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="holo-panel">
      <div class="holo-title">Mentions Timeline ({entityArticles.length} articles)</div>
      {entityArticles.length === 0 && (
        <div style="color: var(--text-dim); font-size: 13px;">No articles found.</div>
      )}
      {entityArticles.map((art) => (
        <div key={art.uuid} style="padding: 10px 0; border-bottom: 1px solid var(--border-default);">
          <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-dim);">{art.date}</div>
          <a href={`${(import.meta.env.BASE_URL || '').replace(/\/$/, '')}/?article=${art.uuid}`} style="font-size: 14px; font-weight: 500; color: var(--text-primary); text-decoration: none;">
            {art.title}
          </a>
          {art.summary && (
            <div style="margin-top: 4px; font-size: 12px; color: var(--text-secondary); line-height: 1.4;">
              {art.summary}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
