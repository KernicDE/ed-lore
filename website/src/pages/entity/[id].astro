---
import BaseLayout from '../../layouts/BaseLayout.astro';
import graphData from '../../data/lore_graph.json';
import { marked } from 'marked';
import SearchIsland from '../../components/hud/SearchIsland';
import EntityGraph from '../../components/graph/EntityGraph';
import type { MiniGraphData, GraphNode, GraphLink } from '../../components/graph/EntityGraph';

export function getStaticPaths() {
  return Object.values(graphData.entities).map((e) => ({
    params: { id: e.id },
  }));
}

const { id } = Astro.params;
const entity = graphData.entities[id] as any;
const baseUrl = (import.meta.env.BASE_URL || '').replace(/\/$/, '');

const entityArticles = graphData.articles
  .filter((a) => {
    const allNames = [...a.entities, ...a.groups, ...a.locations, ...(a.persons || []), ...(a.technologies || [])];
    return allNames.some((n) => n.normalize('NFD').replace(/[̀-ͯ]/g, '').toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '') === id);
  })
  .sort((a, b) => (b.date || '').localeCompare(a.date || ''));

// Display top 6 in the Related Entities panel (scored by shared connections)
const related = (entity?.related_entities || [])
  .slice(0, 6)
  .map((r: any) => graphData.entities[r.id])
  .filter(Boolean);

// Build 2-hop neighbourhood for the mini-map (computed at build time)
const miniNodes: GraphNode[] = [];
const miniLinks: GraphLink[] = [];
const edgeSet = new Set<string>();

if (entity) {
  miniNodes.push({ id: entity.id, name: entity.name, type: entity.type, mentions: entity.mention_count ?? 0, depth: 0 });

  const directIds = new Set<string>();

  for (const rel of (entity.related_entities ?? []) as any[]) {
    const neighbor = (graphData.entities as any)[rel.id];
    if (!neighbor) continue;
    directIds.add(rel.id);
    miniNodes.push({ id: rel.id, name: neighbor.name, type: neighbor.type, mentions: neighbor.mention_count ?? 0, depth: 1 });
    const key = [entity.id, rel.id].sort().join('|');
    if (!edgeSet.has(key)) {
      edgeSet.add(key);
      miniLinks.push({ source: entity.id, target: rel.id, weight: rel.mentions ?? 1 });
    }
  }

  // Edges between direct connections
  for (const rel of (entity.related_entities ?? []) as any[]) {
    const neighbor = (graphData.entities as any)[rel.id];
    if (!neighbor) continue;
    for (const rel2 of (neighbor.related_entities ?? []) as any[]) {
      if (directIds.has(rel2.id) && rel2.id !== entity.id) {
        const key = [rel.id, rel2.id].sort().join('|');
        if (!edgeSet.has(key)) {
          edgeSet.add(key);
          miniLinks.push({ source: rel.id, target: rel2.id, weight: rel2.mentions ?? 1 });
        }
      }
    }
  }

  // 2nd-degree connections (capped at 20)
  const seen = new Set<string>([entity.id, ...directIds]);
  let secondCount = 0;
  outer: for (const rel of (entity.related_entities ?? []) as any[]) {
    const neighbor = (graphData.entities as any)[rel.id];
    if (!neighbor) continue;
    for (const rel2 of (neighbor.related_entities ?? []) as any[]) {
      if (secondCount >= 20) break outer;
      if (!seen.has(rel2.id)) {
        const n2 = (graphData.entities as any)[rel2.id];
        if (!n2) continue;
        seen.add(rel2.id);
        secondCount++;
        miniNodes.push({ id: rel2.id, name: n2.name, type: n2.type, mentions: n2.mention_count ?? 0, depth: 2 });
        const key = [rel.id, rel2.id].sort().join('|');
        if (!edgeSet.has(key)) {
          edgeSet.add(key);
          miniLinks.push({ source: rel.id, target: rel2.id, weight: rel2.mentions ?? 1 });
        }
      }
    }
  }
}

const miniGraphData: MiniGraphData = { nodes: miniNodes, links: miniLinks };

const typeLabels: Record<string, string> = {
  person: 'Person',
  faction: 'Faction / Organisation',
  location: 'System / Location',
  technology: 'Technology / Ship',
};

function formatNumber(n: number): string {
  if (n >= 1_000_000_000) return (n / 1_000_000_000).toFixed(1) + 'B';
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K';
  return String(n);
}
---

<BaseLayout title={`${entity?.name || id} — GalNet Chronicle`}>
  <header class="hud-header">
    <div>
      <a href={`${baseUrl}/`} style="text-decoration: none;" data-home-link>
        <span class="hud-title">‹ GalNet Chronicle</span>
      </a>
    </div>
    <div style="display: flex; align-items: center; gap: 16px;">
      <a href={`${baseUrl}/map/`} class="hud-search-btn hud-map-btn">◈ Map</a>
      <SearchIsland client:idle baseUrl={baseUrl} />
    </div>
  </header>

  <div style="padding: 24px; max-width: 900px; margin: 0 auto;">
    <div class="holo-panel">
      <div style="display: flex; align-items: center; gap: 16px;">
        <div class={`entity-icon ${entity?.type || 'person'}`} style="width: 48px; height: 48px; font-size: 18px;">
          {entity?.type === 'person' ? 'P' : entity?.type === 'faction' ? 'F' : entity?.type === 'technology' ? 'T' : 'L'}
        </div>
        <div style="flex: 1; min-width: 0;">
          <h1 style="margin: 0; font-family: var(--font-hud); font-size: 24px; color: var(--elite-orange);">
            {entity?.name || id}
          </h1>
          <div style="font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); margin-top: 4px;">
            {typeLabels[entity?.type || 'person'] || 'Unknown'} ·
            First seen {entity?.first_seen_date || 'Unknown'} ·
            {entity?.mention_count || 0} mentions
          </div>
        </div>
        {(entity?.edsm_url || entity?.inara_url) && (
          <div class="entity-links">
            {entity?.edsm_url && (
              <a href={entity.edsm_url} target="_blank" rel="noopener" class="entity-link">
                EDSM ↗
              </a>
            )}
            {entity?.inara_url && (
              <a href={entity.inara_url} target="_blank" rel="noopener" class="entity-link">
                Inara ↗
              </a>
            )}
          </div>
        )}
      </div>
      {entity?.last_seen_date && (
        <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-secondary); margin-top: 12px;">
          Active: {entity.first_seen_date} → {entity.last_seen_date}
        </div>
      )}
    </div>

    {/* Bio / Description */}
    {(entity?.bio_full || entity?.bio) && (
      <div class="holo-panel">
        <div class="holo-title">
          {entity?.type === 'person' ? 'Biography'
            : entity?.type === 'location' ? 'System Overview'
            : entity?.type === 'technology' ? 'Technical Overview'
            : 'Description'}
        </div>
        <div class="entity-bio" set:html={marked.parse(entity.bio_full || entity.bio || '')} />
      </div>
    )}

    {/* Location data from EDSM */}
    {entity?.type === 'location' && (
      <div class="holo-panel">
        <div class="holo-title">System Data</div>
        {entity?.coords && (
          <div style="font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary); margin-bottom: 8px;">
            Coordinates: [{entity.coords.x}, {entity.coords.y}, {entity.coords.z}]
          </div>
        )}
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 8px; font-size: 13px;">
          {entity?.allegiance && (
            <div><span style="color: var(--text-dim);">Allegiance:</span> <span style="color: var(--text-primary);">{entity.allegiance}</span></div>
          )}
          {entity?.government && (
            <div><span style="color: var(--text-dim);">Government:</span> <span style="color: var(--text-primary);">{entity.government}</span></div>
          )}
          {entity?.controlling_faction && (
            <div><span style="color: var(--text-dim);">Controlling Faction:</span> <span style="color: var(--text-primary);">{entity.controlling_faction}</span></div>
          )}
          {entity?.security && (
            <div><span style="color: var(--text-dim);">Security:</span> <span style="color: var(--text-primary);">{entity.security}</span></div>
          )}
          {entity?.economy && (
            <div><span style="color: var(--text-dim);">Economy:</span> <span style="color: var(--text-primary);">{entity.economy}</span></div>
          )}
          {entity?.population && (
            <div><span style="color: var(--text-dim);">Population:</span> <span style="color: var(--text-primary);">{formatNumber(entity.population)}</span></div>
          )}
        </div>
      </div>
    )}

    {/* Relationship mini-map */}
    {miniNodes.length > 1 && (
      <div class="holo-panel" style="padding: 0; overflow: hidden;">
        <div style="padding: 20px 20px 0;"><div class="holo-title">Connection Map</div></div>
        <EntityGraph client:visible mode="mini" miniData={miniGraphData} baseUrl={baseUrl} />
      </div>
    )}

    {related.length > 0 && (
      <div class="holo-panel blue">
        <div class="holo-title blue">Related Entities</div>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 8px;">
          {related.map((rel: any) => (
            <a href={`${baseUrl}/entity/${rel.id}/`} class="entity-card" style="text-decoration: none;">
              <div class={`entity-icon ${rel.type || 'person'}`}>
                {rel.type === 'person' ? 'P' : rel.type === 'faction' ? 'F' : rel.type === 'technology' ? 'T' : 'L'}
              </div>
              <div>
                <div class="entity-name">{rel.name}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="holo-panel">
      <div class="holo-title">Mentions Timeline ({entityArticles.length} articles)</div>
      {entityArticles.length === 0 && (
        <div style="color: var(--text-dim); font-size: 13px;">No articles found.</div>
      )}
      {entityArticles.map((art) => (
        <div key={art.uuid} style="padding: 10px 0; border-bottom: 1px solid var(--border-default);">
          <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-dim);">{art.date}</div>
          <a href={`${baseUrl}/?article=${art.uuid}`} style="font-size: 14px; font-weight: 500; color: var(--text-primary); text-decoration: none;">
            {art.title}
          </a>
          {art.summary && (
            <div style="margin-top: 4px; font-size: 12px; color: var(--text-secondary); line-height: 1.4;">
              {art.summary}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
