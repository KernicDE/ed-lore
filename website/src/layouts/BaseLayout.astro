---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}
const { 
  title = "GalNet Chronicle — Elite Dangerous Lore Explorer",
  description = "Explore the complete Elite Dangerous GalNet archive from 3301–3312. AI-enriched articles, entity profiles, story arcs, and interactive timeline.",
  ogImage = "/ed-lore/favicon.svg",
  canonical,
} = Astro.props;

const baseUrl = "https://kernicde.github.io/ed-lore";
const canonicalUrl = canonical ? `${baseUrl}${canonical}` : baseUrl + Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="Elite Dangerous, GalNet, lore, timeline, ED, frontier, space simulation, galaxy, articles" />
  <meta name="author" content="GalNet Chronicle" />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#080a0f" />
  <meta name="color-scheme" content="dark" />
  
  <!-- Canonical -->
  <link rel="canonical" href={canonicalUrl} />
  
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${baseUrl}${ogImage}`} />
  <meta property="og:site_name" content="GalNet Chronicle" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${baseUrl}${ogImage}`} />
  
  <!-- RSS / Atom Auto-discovery -->
  <link rel="alternate" type="application/rss+xml" title="GalNet Chronicle RSS" href={`${(import.meta.env.BASE_URL || '').replace(/\/$/, '')}/rss.xml`} />
  <link rel="alternate" type="application/atom+xml" title="GalNet Chronicle Atom" href={`${(import.meta.env.BASE_URL || '').replace(/\/$/, '')}/atom.xml`} />
  
  <!-- PWA -->
  <link rel="manifest" href={`${(import.meta.env.BASE_URL || '').replace(/\/$/, '')}/manifest.json`} />
  <link rel="icon" type="image/svg+xml" href={`${(import.meta.env.BASE_URL || '').replace(/\/$/, '')}/favicon.svg`} />
  <link rel="apple-touch-icon" href={`${(import.meta.env.BASE_URL || '').replace(/\/$/, '')}/favicon.svg`} />
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Exo+2:wght@400;500;600;700&display=swap" rel="stylesheet" />
  
  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "GalNet Chronicle",
    "description": description,
    "url": baseUrl,
    "potentialAction": {
      "@type": "SearchAction",
      "target": `${baseUrl}/?search={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  })} />
  
  <style is:global>
    @import "../styles/elite-hud.css";
  </style>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <div id="app-root">
    <slot />
  </div>
  
  <!-- Service Worker Registration -->
  <script is:inline>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', function() {
        navigator.serviceWorker.register('/ed-lore/sw.js').catch(function(err) {
          console.log('SW registration failed:', err);
        });
      });
    }
  </script>
</body>
</html>
